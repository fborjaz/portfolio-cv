# OpenAI API Key para el chatbot con IA (opcional, hay modo fallback)
OPENAI_API_KEY=tu-api-key-aqui

# Resend — envío del formulario de contacto
# Consigue tu key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Remitente verificado en Resend. En sandbox usa onboarding@resend.dev
# (solo entrega al email de tu cuenta). En prod usa un dominio verificado.
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
# Destino del correo. En sandbox DEBE ser el email de tu cuenta Resend.
# Déjalo vacío en prod (con dominio verificado) para usar el email del CV.
CONTACT_TO_EMAIL=

# Upstash Redis (opcional) — rate limit distribuido para prod serverless.
# Sin estas vars, el rate limit cae a memoria local automáticamente.
# Consíguelas en https://console.upstash.com (Redis > REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
